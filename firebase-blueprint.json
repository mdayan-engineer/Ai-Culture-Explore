{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile data",
      "type": "object",
      "properties": {
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["email", "role", "createdAt"]
    },
    "SavedDestination": {
      "title": "Saved Destination",
      "description": "A destination saved by the user",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "bestSeason": { "type": "string" },
        "costEstimate": { "type": "string" },
        "travelStyle": { "type": "string" },
        "description": { "type": "string" },
        "savedAt": { "type": "object" }
      },
      "required": ["name", "savedAt"]
    },
    "Trip": {
      "title": "Trip",
      "type": "object",
      "properties": {
        "ownerId": { "type": "string" },
        "title": { "type": "string" },
        "destination": { "type": "string" },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "required": ["ownerId", "title", "createdAt", "updatedAt"]
    },
    "TripMember": {
      "title": "Trip Member",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "role": { "type": "string" },
        "joinedAt": { "type": "string" }
      },
      "required": ["userId", "role", "joinedAt"]
    },
    "TripActivity": {
      "title": "Trip Activity",
      "type": "object",
      "properties": {
        "creatorId": { "type": "string" },
        "title": { "type": "string" },
        "date": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["creatorId", "title", "createdAt"]
    },
    "CommunityPost": {
      "title": "Community Post",
      "type": "object",
      "properties": {
        "authorId": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["authorId", "title", "content", "createdAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Users"
    },
    "users/{userId}/savedDestinations/{destId}": {
      "schema": { "$ref": "#/entities/SavedDestination" },
      "description": "Saved destinations for a user"
    },
    "trips/{tripId}": {
      "schema": { "$ref": "#/entities/Trip" },
      "description": "Trips"
    },
    "trips/{tripId}/members/{memberId}": {
      "schema": { "$ref": "#/entities/TripMember" },
      "description": "Members of a trip"
    },
    "trips/{tripId}/activities/{activityId}": {
      "schema": { "$ref": "#/entities/TripActivity" },
      "description": "Activities in a trip"
    },
    "communityPosts/{postId}": {
      "schema": { "$ref": "#/entities/CommunityPost" },
      "description": "Community posts"
    }
  }
}
