rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isValidUser(data) {
      return data.keys().hasAll(['email', 'role', 'createdAt']) &&
             data.email is string && data.email.size() <= 256 &&
             data.role is string && data.role.size() <= 20 &&
             data.createdAt is string && data.createdAt.size() <= 50;
    }

    function isValidSavedDestination(data) {
      return data.keys().hasAll(['name', 'savedAt']) &&
             data.name is string && data.name.size() <= 200;
    }

    function isValidTrip(data) {
      return data.keys().hasAll(['ownerId', 'title', 'createdAt', 'updatedAt']) &&
             data.ownerId is string && data.ownerId.size() <= 128 &&
             data.title is string && data.title.size() <= 200 &&
             data.createdAt is string && data.createdAt.size() <= 50 &&
             data.updatedAt is string && data.updatedAt.size() <= 50;
    }

    function isValidTripMember(data) {
      return data.keys().hasAll(['userId', 'role', 'joinedAt']) &&
             data.userId is string && data.userId.size() <= 128 &&
             data.role is string && data.role.size() <= 20 &&
             data.joinedAt is string && data.joinedAt.size() <= 50;
    }

    function isValidTripActivity(data) {
      return data.keys().hasAll(['creatorId', 'title', 'createdAt']) &&
             data.creatorId is string && data.creatorId.size() <= 128 &&
             data.title is string && data.title.size() <= 200 &&
             data.createdAt is string && data.createdAt.size() <= 50;
    }

    function isValidCommunityPost(data) {
      return data.keys().hasAll(['authorId', 'title', 'content', 'createdAt']) &&
             data.authorId is string && data.authorId.size() <= 128 &&
             data.title is string && data.title.size() <= 200 &&
             data.content is string && data.content.size() <= 5000 &&
             data.createdAt is string && data.createdAt.size() <= 50;
    }

    match /users/{userId} {
      allow get: if isSignedIn() && isValidId(userId) && (request.auth.uid == userId || isAdmin());
      allow list: if isAdmin();
      allow create: if isSignedIn() && isValidId(userId) &&
                    request.auth.uid == userId &&
                    isValidUser(incoming()) &&
                    incoming().role == 'user';
      allow update: if isSignedIn() && isValidId(userId) &&
                    (request.auth.uid == userId || isAdmin()) &&
                    isValidUser(incoming()) &&
                    (isAdmin() || incoming().role == existing().role) &&
                    incoming().createdAt == existing().createdAt;
      allow delete: if isAdmin() && isValidId(userId);

      match /savedDestinations/{destId} {
        allow get, list: if isSignedIn() && isValidId(userId) && request.auth.uid == userId;
        allow create: if isSignedIn() && isValidId(userId) && isValidId(destId) &&
                      request.auth.uid == userId &&
                      isValidSavedDestination(incoming());
        allow update: if isSignedIn() && isValidId(userId) && isValidId(destId) &&
                      request.auth.uid == userId &&
                      isValidSavedDestination(incoming());
        allow delete: if isSignedIn() && isValidId(userId) && isValidId(destId) && request.auth.uid == userId;
      }
    }

    match /trips/{tripId} {
      allow get: if isSignedIn() && isValidId(tripId) && (
        existing().ownerId == request.auth.uid || 
        exists(/databases/$(database)/documents/trips/$(tripId)/members/$(request.auth.uid)) ||
        isAdmin()
      );
      allow list: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow create: if isSignedIn() && isValidId(tripId) &&
                    isValidTrip(incoming()) &&
                    incoming().ownerId == request.auth.uid &&
                    incoming().createdAt == request.time &&
                    incoming().updatedAt == request.time;
      allow update: if isSignedIn() && isValidId(tripId) &&
                    isValidTrip(incoming()) &&
                    existing().ownerId == request.auth.uid &&
                    incoming().ownerId == existing().ownerId &&
                    incoming().createdAt == existing().createdAt &&
                    incoming().updatedAt == request.time;
      allow delete: if isSignedIn() && isValidId(tripId) && existing().ownerId == request.auth.uid;

      match /members/{memberId} {
        allow get, list: if isSignedIn() && isValidId(tripId) && isValidId(memberId) && (
          get(/databases/$(database)/documents/trips/$(tripId)).data.ownerId == request.auth.uid ||
          exists(/databases/$(database)/documents/trips/$(tripId)/members/$(request.auth.uid))
        );
        allow create: if isSignedIn() && isValidId(tripId) && isValidId(memberId) &&
                      get(/databases/$(database)/documents/trips/$(tripId)).data.ownerId == request.auth.uid &&
                      isValidTripMember(incoming());
        allow update: if isSignedIn() && isValidId(tripId) && isValidId(memberId) &&
                      get(/databases/$(database)/documents/trips/$(tripId)).data.ownerId == request.auth.uid &&
                      isValidTripMember(incoming());
        allow delete: if isSignedIn() && isValidId(tripId) && isValidId(memberId) &&
                      get(/databases/$(database)/documents/trips/$(tripId)).data.ownerId == request.auth.uid;
      }

      match /activities/{activityId} {
        allow get, list: if isSignedIn() && isValidId(tripId) && isValidId(activityId) && (
          get(/databases/$(database)/documents/trips/$(tripId)).data.ownerId == request.auth.uid ||
          exists(/databases/$(database)/documents/trips/$(tripId)/members/$(request.auth.uid))
        );
        allow create: if isSignedIn() && isValidId(tripId) && isValidId(activityId) &&
                      (get(/databases/$(database)/documents/trips/$(tripId)).data.ownerId == request.auth.uid ||
                      exists(/databases/$(database)/documents/trips/$(tripId)/members/$(request.auth.uid))) &&
                      isValidTripActivity(incoming()) &&
                      incoming().creatorId == request.auth.uid;
        allow update: if isSignedIn() && isValidId(tripId) && isValidId(activityId) &&
                      (get(/databases/$(database)/documents/trips/$(tripId)).data.ownerId == request.auth.uid ||
                      exists(/databases/$(database)/documents/trips/$(tripId)/members/$(request.auth.uid))) &&
                      isValidTripActivity(incoming()) &&
                      incoming().creatorId == existing().creatorId &&
                      incoming().createdAt == existing().createdAt;
        allow delete: if isSignedIn() && isValidId(tripId) && isValidId(activityId) && (
          get(/databases/$(database)/documents/trips/$(tripId)).data.ownerId == request.auth.uid ||
          existing().creatorId == request.auth.uid
        );
      }
    }

    match /communityPosts/{postId} {
      allow get: if isSignedIn() && isValidId(postId);
      allow list: if isSignedIn(); // In a real app this would be more restricted but it's public feed
      allow create: if isSignedIn() && isValidId(postId) &&
                    isValidCommunityPost(incoming()) &&
                    incoming().authorId == request.auth.uid &&
                    incoming().createdAt == request.time;
      allow update: if isSignedIn() && isValidId(postId) &&
                    isValidCommunityPost(incoming()) &&
                    existing().authorId == request.auth.uid &&
                    incoming().authorId == existing().authorId &&
                    incoming().createdAt == existing().createdAt;
      allow delete: if isSignedIn() && isValidId(postId) && (existing().authorId == request.auth.uid || isAdmin());
    }
  }
}
